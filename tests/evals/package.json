{
  "name": "@engineering-skills/evals",
  "private": true,
  "description": "Promptfoo eval harness for engineering-skills",
  "scripts": {
    "eval": "npm run eval:creating-linear-issue && npm run eval:creating-linear-issue-routing && npm run eval:implementing-linear-issue && npm run eval:raising-linear-pr && npm run eval:closing-linear-issue && npm run eval:maintain-github-repos && npm run eval:create-feature-request && npm run eval:writing-tests && npm run eval:e2e-adding-scenario && npm run eval:e2e-authoring-feature-file && npm run eval:e2e-extending-step-vocabulary && npm run eval:e2e-regenerating-from-guide && npm run eval:yolo && npm run eval:yolo-routing && npm run test:promptfoo-db-gate && npm run eval:coverage && npm run eval:codex-compatibility",
    "eval:creating-linear-issue": "./scripts/promptfoo.sh eval --no-cache -c packages/creating-linear-issue/skill-creating-linear-issue.yaml",
    "eval:creating-linear-issue-routing": "./scripts/promptfoo.sh eval --no-cache -c packages/creating-linear-issue/skill-creating-linear-issue-routing.yaml",
    "eval:implementing-linear-issue": "./scripts/promptfoo.sh eval --no-cache -c packages/implementing-linear-issue/skill-implementing-linear-issue.yaml",
    "eval:raising-linear-pr": "./scripts/promptfoo.sh eval --no-cache -c packages/raising-linear-pr/skill-raising-linear-pr.yaml",
    "eval:closing-linear-issue": "./scripts/promptfoo.sh eval --no-cache -c packages/closing-linear-issue/skill-closing-linear-issue.yaml",
    "eval:maintain-github-repos": "./scripts/promptfoo.sh eval --no-cache -c packages/maintain-github-repos/skill-maintain-github-repos.yaml",
    "eval:create-feature-request": "./scripts/promptfoo.sh eval --no-cache -c packages/create-feature-request/skill-create-feature-request.yaml",
    "eval:writing-tests": "./scripts/promptfoo.sh eval --no-cache -c packages/writing-tests/skill-writing-tests.yaml",
    "eval:e2e-adding-scenario": "./scripts/promptfoo.sh eval --no-cache -c packages/e2e-adding-scenario/skill-e2e-adding-scenario.yaml",
    "eval:e2e-authoring-feature-file": "./scripts/promptfoo.sh eval --no-cache -c packages/e2e-authoring-feature-file/skill-e2e-authoring-feature-file.yaml",
    "eval:e2e-extending-step-vocabulary": "./scripts/promptfoo.sh eval --no-cache -c packages/e2e-extending-step-vocabulary/skill-e2e-extending-step-vocabulary.yaml",
    "eval:e2e-regenerating-from-guide": "./scripts/promptfoo.sh eval --no-cache -c packages/e2e-regenerating-from-guide/skill-e2e-regenerating-from-guide.yaml",
    "eval:yolo": "./scripts/promptfoo.sh eval --no-cache -c packages/yolo/skill-yolo.yaml",
    "eval:yolo-routing": "./scripts/promptfoo.sh eval --no-cache -c packages/yolo/skill-yolo-routing.yaml",
    "eval:coverage": "node scripts/check-skill-eval-coverage.js",
    "eval:codex-compatibility": "node scripts/check-codex-compatibility.js",
    "test:opencode-cli-provider": "node --test scripts/opencode-cli-provider.test.js",
    "test:eval-harness-contract": "node --test scripts/eval-harness-contract.test.js",
    "test:promptfoo-db-gate": "node --test scripts/promptfoo-db-gate.test.js",
    "view": "./scripts/promptfoo.sh view"
  },
  "dependencies": {
    "@opencode-ai/sdk": "1.14.21",
    "promptfoo": "0.121.7"
  }
}
