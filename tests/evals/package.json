{
  "name": "@engineering-skills/evals",
  "private": true,
  "description": "Promptfoo eval harness for engineering-skills",
  "scripts": {
    "eval": "npm run eval:creating-linear-issue && npm run eval:creating-linear-issue-routing && npm run eval:implementing-linear-issue && npm run eval:raising-linear-pr && npm run eval:closing-linear-issue && npm run eval:maintain-github-repos",
    "eval:creating-linear-issue": "./scripts/promptfoo.sh eval --no-cache -c packages/creating-linear-issue/skill-creating-linear-issue.yaml",
    "eval:creating-linear-issue-routing": "./scripts/promptfoo.sh eval --no-cache -c packages/creating-linear-issue/skill-creating-linear-issue-routing.yaml",
    "eval:implementing-linear-issue": "./scripts/promptfoo.sh eval --no-cache -c packages/implementing-linear-issue/skill-implementing-linear-issue.yaml",
    "eval:raising-linear-pr": "./scripts/promptfoo.sh eval --no-cache -c packages/raising-linear-pr/skill-raising-linear-pr.yaml",
    "eval:closing-linear-issue": "./scripts/promptfoo.sh eval --no-cache -c packages/closing-linear-issue/skill-closing-linear-issue.yaml",
    "eval:maintain-github-repos": "./scripts/promptfoo.sh eval --no-cache -c packages/maintain-github-repos/skill-maintain-github-repos.yaml",
    "view": "./scripts/promptfoo.sh view"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.94",
    "@anthropic-ai/claude-code": "^2.1.92",
    "promptfoo": "latest"
  },
  "overrides": {
    "@anthropic-ai/sdk": ">=0.81.0"
  }
}
